{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/openclaw/clawsweeper/blob/main/schema/state-ledger-event.schema.json",
  "title": "ClawSweeper state ledger event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "schema_version",
    "event_id",
    "event_key",
    "semantic_sha256",
    "occurred_at",
    "recorded_at",
    "event_type",
    "producer",
    "subject",
    "action",
    "privacy"
  ],
  "properties": {
    "schema": {
      "const": "clawsweeper.state-ledger-event.v1"
    },
    "schema_version": {
      "const": 1
    },
    "event_id": {
      "$ref": "#/$defs/sha256"
    },
    "event_key": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "semantic_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "recorded_at": {
      "type": "string",
      "format": "date-time"
    },
    "event_type": {
      "$ref": "#/$defs/machineText"
    },
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "sha", "workflow", "job", "run_id", "run_attempt", "component"],
      "properties": {
        "repository": {
          "$ref": "#/$defs/repository"
        },
        "sha": {
          "$ref": "#/$defs/machineText"
        },
        "workflow": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "job": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "run_id": {
          "$ref": "#/$defs/machineText"
        },
        "run_attempt": {
          "type": "integer",
          "minimum": 1
        },
        "component": {
          "$ref": "#/$defs/machineText"
        }
      }
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "kind"],
      "properties": {
        "repository": {
          "$ref": "#/$defs/repository"
        },
        "kind": {
          "enum": [
            "issue",
            "pull_request",
            "cluster",
            "command",
            "workflow",
            "repository",
            "notification"
          ]
        },
        "number": {
          "type": "integer",
          "minimum": 1
        },
        "cluster_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "source_revision": {
          "$ref": "#/$defs/machineText"
        },
        "record_path": {
          "$ref": "#/$defs/relativePath"
        }
      }
    },
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "status", "retryable", "mutation"],
      "properties": {
        "name": {
          "$ref": "#/$defs/machineText"
        },
        "status": {
          "$ref": "#/$defs/machineText"
        },
        "reason_code": {
          "$ref": "#/$defs/machineText"
        },
        "retryable": {
          "type": "boolean"
        },
        "mutation": {
          "type": "boolean"
        }
      }
    },
    "learning": {
      "type": "object",
      "additionalProperties": false,
      "required": ["category", "signal"],
      "properties": {
        "category": {
          "$ref": "#/$defs/machineText"
        },
        "signal": {
          "$ref": "#/$defs/machineText"
        },
        "rule_id": {
          "$ref": "#/$defs/machineText"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "evidence": {
      "type": "array",
      "maxItems": 64,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind"],
        "properties": {
          "kind": {
            "$ref": "#/$defs/machineText"
          },
          "sha256": {
            "$ref": "#/$defs/sha256"
          },
          "report_path": {
            "$ref": "#/$defs/relativePath"
          },
          "run_url": {
            "type": "string",
            "format": "uri",
            "pattern": "^https://github\\.com/"
          },
          "snapshot_id": {
            "$ref": "#/$defs/machineText"
          }
        }
      }
    },
    "attributes": {
      "type": "object",
      "propertyNames": {
        "enum": [
          "attempt",
          "cache_mode",
          "cached",
          "candidate_count",
          "closed_count",
          "completion_reason",
          "cost_usd_micros",
          "coverage_complete",
          "coverage_ratio",
          "dispatch_kind",
          "duration_ms",
          "failed_count",
          "finding_count",
          "input_tokens",
          "item_count",
          "model",
          "output_tokens",
          "phase",
          "query_version",
          "reasoning_effort",
          "result_count",
          "review_mode",
          "shard_count",
          "shard_index",
          "skipped_count",
          "state",
          "work_kind"
        ]
      },
      "additionalProperties": {
        "oneOf": [
          {
            "$ref": "#/$defs/scalar"
          },
          {
            "type": "array",
            "maxItems": 64,
            "items": {
              "$ref": "#/$defs/scalar"
            }
          }
        ]
      }
    },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["classification", "redaction_version", "fields_dropped"],
      "properties": {
        "classification": {
          "enum": ["public", "internal"]
        },
        "redaction_version": {
          "$ref": "#/$defs/machineText"
        },
        "fields_dropped": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/machineText"
          }
        }
      }
    }
  },
  "$defs": {
    "machineText": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:/@+\\-]*$"
    },
    "repository": {
      "type": "string",
      "pattern": "^[a-z0-9_][a-z0-9_.-]*/[a-z0-9_][a-z0-9_.-]*$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "not": {
        "anyOf": [
          {
            "pattern": "^(?:/|[A-Za-z]:[\\\\/])"
          },
          {
            "pattern": "(?:^|[\\\\/])\\.\\.(?:[\\\\/]|$)"
          }
        ]
      }
    },
    "scalar": {
      "oneOf": [
        {
          "type": "string",
          "maxLength": 512
        },
        {
          "type": "number"
        },
        {
          "type": "boolean"
        },
        {
          "type": "null"
        }
      ]
    }
  }
}
